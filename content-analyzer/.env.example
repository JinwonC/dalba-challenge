# --- Required ---
# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Apify API token (https://console.apify.com/account/integrations)
APIFY_TOKEN=apify_api_...

# --- Optional ---
# Port for the web server
PORT=3000

# Claude model to use for analysis
ANTHROPIC_MODEL=claude-opus-4-8

# Apify actors. Override only if you want to use different actors.
# YouTube video metadata + (optionally) subtitles:
APIFY_YOUTUBE_ACTOR=streamers/youtube-scraper
# YouTube transcript (separate, more reliable for captions):
APIFY_YOUTUBE_TRANSCRIPT_ACTOR=pintostudio/youtube-transcript-scraper
# TikTok video metadata + subtitles + stats:
APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
